@using Logging_And_Exceptions_Handling.Models
@model List<Products>

@{
    ViewBag.Title = "Home Page";
}

<h1>Logging Section</h1>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Price</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Price</td>
            </tr>
        }

    </tbody>
</table>